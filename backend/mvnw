# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

# Find the project base dir, i.e. the directory that contains the folder ".mvn".
find_maven_basedir() {
    basedir=$(dirname "$0")
    wdir=$basedir
    while [ "$wdir" != '/' ] ; do
        if [ -d "$wdir"/.mvn ] ; then
            basedir=$wdir
            break
        fi
        wdir=$(cd "$wdir/.." && pwd)
    done
    printf '%s' "$(cd "$basedir" && pwd)"
}

BASE_DIR=$(find_maven_basedir)
MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}

MAVEN_WRAPPER_PROPERTIES_PATH="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES_PATH" ] ; then
    DISTRIBUTION_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES_PATH" | cut -d= -f2-)
    WRAPPER_JAR_URL=$(grep wrapperUrl "$MAVEN_WRAPPER_PROPERTIES_PATH" | cut -d= -f2-)
fi

MAVEN_USER_HOME=${MAVEN_USER_HOME:-"$HOME/.m2"}
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ -r "$MAVEN_WRAPPER_JAR" ] ; then
    :
else
    echo "Downloading Maven Wrapper JAR..."
    curl -o "$MAVEN_WRAPPER_JAR" -fsSL "$WRAPPER_JAR_URL" 2>/dev/null || \
    wget -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_JAR_URL" 2>/dev/null
fi

if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD=$(command -v java)
fi

if [ ! -x "$JAVACMD" ] ; then
    echo "Java executable not found. Configure JAVA_HOME or add java to PATH." >&2
    exit 1
fi

exec "$JAVACMD" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  -classpath "$MAVEN_WRAPPER_JAR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
